// For format details, see https://aka.ms/devcontainer.json.
{
	"name": "Intel POE CoRIM I-D Toolchain",
	// More info: https://containers.dev/guide/dockerfile
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"http_proxy": "${localEnv:http_proxy}",
			"https_proxy": "${localEnv:https_proxy}",
			"no_proxy": "${localEnv:no_proxy}"
		}
	},
	
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {	
		"ghcr.io/hspaans/devcontainer-features/pymarkdownlnt:1": {
			"version": "latest"
		}
		// ,
		// "ghcr.io/devcontainers-extra/features/markdownlint-cli2:1": {
		// 	"version": "latest"
		// }
	},
	
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [3000],
	"portsAttributes": {
		"3000": {
			"label": "KDWatch",
			"description": "Auto-updated HTML version of the documentation",
			"onAutoForward": "openBrowserOnce"
		}
	},
	
	"containerEnv": {
		"HTTP_PROXY": "${localEnv:HTTP_PROXY}",
		"HTTPS_PROXY": "${localEnv:HTTP_PROXY}",
		"http_proxy": "${localEnv:HTTP_PROXY}",
		"https_proxy": "${localEnv:HTTP_PROXY}",
		"no_proxy": "${localEnv:NO_PROXY}",
		"NO_PROXY": "${localEnv:NO_PROXY}"
	},

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "rm -rf ./lib; make", // remove previously downloaded libraries on devcontainer change (to force toolchain update) & I-D toolchain
	"postStartCommand": "nohup bash -c 'kdwatch -p 3000 &' >./kdwatch.out~ 2>&1", // start kdwatch in the background
	"postAttachCommand": "echo -e '\\n\\n=========\\n= \\e[34mNOTICE\\e[37m: - kdwatch with I-D preview started on port 3000, open http://localhost:3000 in your browser (or navigate Ports tab in VSCode)\\n=         - mermaid-ascii is available in the shell for quick conversion between mermaid and ASCII diagrams\\n=         - CoRIM/CDDL tooling: cddl (validate the Appendix grammar / check CBOR against it) + cbor-diag (cbor2diag.rb, diag2cbor.rb, cbor2pretty.rb) for the cbor-diag examples\\n=         - scripts/validate-cddl.sh: validate the POE CoRIM profile CDDL appendix against the base CoRIM grammar (add -i example.cbor to check an instance, -g to generate a sample)\\e[0m\\n=========\\n'",
	
	// Configure tool-specific properties.
	"customizations": {
		"codespaces": {
			"openFiles": [
				"draft-bzb-rats-intel-poe-endorsements.md"
			]
		},
		"vscode": {
			"extensions": [
				"davidanson.vscode-markdownlint",
				"bierner.markdown-mermaid",
				"mermaidchart.vscode-mermaid-chart",
				"shd101wyy.markdown-preview-enhanced",
				"shd101wyy.markdown-preview-enhanced-plus",
				"francescoboffa.rfc-reader",
				"ms-vscode.live-server",
				"anweiss.cddl-languageserver",
				"gabrielkerekes.cbor"
			],
			"settings": {}
		}
	}
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
